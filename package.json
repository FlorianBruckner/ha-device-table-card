{
  "name": "ha-device-table-card",
  "version": "0.0.2",
  "description": "A Home Assistant dashboard card to show devices as a table using DataTables.net",
  "type": "module",
  "main": "dist/device-table-card.js",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w",
    "lint": "eslint src",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "format:write": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "home-assistant",
    "hacs",
    "custom-card",
    "datatables"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "datatables.net": "^2.1.8",
    "datatables.net-dt": "^2.1.8",
    "datatables.net-responsive-dt": "^3.0.3",
    "jquery": "^3.7.1",
    "lit": "^3.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@rollup/plugin-commonjs": "^28.0.1",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-typescript": "^12.1.1",
    "@testing-library/dom": "^10.4.1",
    "@types/datatables.net": "^1.10.28",
    "@types/jquery": "^4.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "custom-card-helpers": "^1.9.0",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "rollup": "^4.24.0",
    "rollup-plugin-import-css": "^4.2.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.11.0",
    "vitest": "^4.1.9"
  }
}
